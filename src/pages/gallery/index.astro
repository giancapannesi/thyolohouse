---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGallery, siteInfo } from '../../utils/data';

const gallery = getGallery();
const categories = ['all', ...new Set(gallery.map((img) => img.category))];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "name": "Photo Gallery — The Thyolo House",
    "description": "Photos of The Thyolo House, its rooms, restaurant, gardens, and experiences on the Conforzi Tea Estate.",
    "url": `${siteInfo.url}/gallery/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Gallery", "item": `${siteInfo.url}/gallery/` }
    ]
  }
];

const categoryLabels: Record<string, string> = {
  all: 'All',
  art: 'Art',
  rooms: 'Rooms',
  grounds: 'Grounds',
  property: 'Property',
  restaurant: 'Restaurant',
};

// Assign varied aspect ratios for masonry effect
const aspectClasses = ['aspect-[4/3]', 'aspect-[3/4]', 'aspect-square', 'aspect-[4/3]', 'aspect-square', 'aspect-[3/4]'];
---

<BaseLayout
  title="Gallery"
  description="Browse photos of The Thyolo House — the colonial main house, rooms, Italian fusion restaurant, swimming pool, tea gardens, and indigenous forest on the Conforzi Estate."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
      <p class="label-caps mb-6">Photography</p>
      <h1 class="text-5xl md:text-7xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">
        Gallery
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed" style="font-weight: 300;">
        A glimpse of life at The Thyolo House and the Conforzi Tea Estate.
      </p>
    </div>
  </section>

  <!-- Filter Buttons -->
  <section class="py-6 border-b border-border sticky top-16 md:top-20 z-40 bg-bg/95 backdrop-blur">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-4">
        {categories.map((cat) => (
          <button
            class="gallery-filter label-caps px-4 py-2 border-b-2 border-transparent transition-colors hover:text-text hover:border-text"
            data-category={cat}
          >
            {categoryLabels[cat] || cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Masonry Gallery Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4" id="gallery-grid">
        {gallery.map((img, i) => (
          <div
            class="gallery-item break-inside-avoid relative group"
            data-category={img.category}
          >
            <div class={`relative overflow-hidden ${aspectClasses[i % aspectClasses.length]}`}>
              <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
              <!-- Hover overlay with alt text -->
              <div class="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/60 transition-colors duration-300 z-10 flex items-end p-6">
                <p class="text-linen text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="font-weight: 300;">
                  {img.alt}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.gallery-filter');
      const items = document.querySelectorAll('.gallery-item');

      // Set initial active state
      const allBtn = document.querySelector('[data-category="all"]');
      if (allBtn) {
        allBtn.classList.add('border-text', 'text-text');
        allBtn.classList.remove('border-transparent');
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const category = btn.getAttribute('data-category');

          // Update button styles
          buttons.forEach((b) => {
            b.classList.remove('border-text', 'text-text');
            b.classList.add('border-transparent');
          });
          btn.classList.add('border-text', 'text-text');
          btn.classList.remove('border-transparent');

          // Filter items
          items.forEach((item) => {
            const itemCat = item.getAttribute('data-category');
            if (category === 'all' || itemCat === category) {
              (item as HTMLElement).style.display = '';
            } else {
              (item as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    });
  </script>

</BaseLayout>
