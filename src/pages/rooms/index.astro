---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteInfo } from '../../utils/data';

const whatsappBook = `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent("Hello! I'd like to enquire about staying at The Thyolo House.")}`;

const spaces = [
  {
    name: 'The Heritage Suite',
    label: 'Master Bedroom',
    image: '/images/rooms/heritage-suite.jpg',
    alt: 'The Heritage Suite — hand-carved African headboard, mosquito net, Persian rug, sunlight through French doors',
    description: 'The signature room of the house. A hand-carved African headboard, white linen under a mosquito net canopy, antique furniture, and golden light pouring through French doors onto a Persian rug. The room opens directly onto the garden.',
    detail: 'En-suite bathroom · Garden view · Mosquito net · Antique furnishings',
  },
  {
    name: 'The Pool',
    label: 'Grounds',
    image: '/images/estate/pool-area.jpg',
    alt: 'The swimming pool — turquoise water surrounded by brick terrace, tropical palms, and a vine-covered gazebo',
    description: 'A turquoise jewel set in red brick, surrounded by palm trees and a vine-covered gazebo. The pool is shared between the main house and the cottages — a cool retreat after exploring the tea gardens or the forest trails beyond.',
    detail: 'Brick terrace · Shaded gazebo · Sun loungers · Poolside service',
  },
  {
    name: 'The Pool Cottage',
    label: 'Accommodation',
    image: '/images/rooms/pool-cottage-room.jpg',
    alt: 'The Pool Cottage — ochre walls, vaulted white ceiling, dark polished floors, bed with mosquito net canopy, and Persian rug',
    description: 'A private cottage steps from the pool, with ochre walls rising to a vaulted white ceiling, dark polished timber floors, and a bed draped in white linen under a mosquito net canopy. French doors open onto the garden. Self-contained and peaceful.',
    detail: 'En-suite bathroom · Private veranda · Pool access · Self-catering available',
  },
  {
    name: 'The Tree of Life Room',
    label: 'Bedroom',
    image: '/images/rooms/tree-mural.jpg',
    alt: 'The Tree of Life Room — Klimt-inspired mural painted behind the bed with golden spirals and a toucan',
    description: 'Named for Flavia\'s hand-painted mural — a Klimt-inspired Tree of Life in gold and earth tones, complete with a hidden toucan. Deep purple cushions against white linen. Every room in this house is a work of art.',
    detail: 'Hand-painted mural · En-suite bathroom · Mosquito net · Garden view',
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": siteInfo.name,
    "description": "A historic colonial farmhouse on the Conforzi Tea Estate — bedrooms, swimming pool, and private cottages surrounded by tea gardens and forest.",
    "url": `${siteInfo.url}/rooms/`,
    "telephone": siteInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Conforzi Tea Estate",
      "addressLocality": "Thyolo",
      "addressCountry": "MW"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Where You'll Stay", "item": `${siteInfo.url}/rooms/` }
    ]
  }
];
---

<BaseLayout
  title="Where You'll Stay"
  description="Explore The Thyolo House — the Heritage Suite, swimming pool, and private cottages on the Conforzi Tea Estate in Thyolo, Malawi."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
      <p class="label-caps mb-6">The House</p>
      <h1 class="text-5xl md:text-7xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">
        Where You'll Stay
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        A colonial farmhouse built in the early 1900s, extended and lovingly restored over generations.
        Every room has its own character — hand-painted murals, carved African headboards, a baby grand piano,
        and art on every wall. This is not a hotel. It's a home.
      </p>
    </div>
  </section>

  <div class="ornament max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">&#10038;</div>

  <!-- Spaces — Alternating Editorial Blocks -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-20 md:space-y-32">
        {spaces.map((space, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center`}>

            <!-- Image -->
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="overflow-hidden">
                <img
                  src={space.image}
                  alt={space.alt}
                  class="w-full aspect-[4/3] object-cover hover:scale-105 transition-transform duration-500"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
            </div>

            <!-- Text -->
            <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
              <p class="label-caps mb-4">{space.label}</p>

              <h2 class="text-3xl md:text-4xl text-text mb-6" style="font-family: var(--font-heading); font-weight: 300;">
                {space.name}
              </h2>

              <p class="text-muted leading-relaxed mb-8">
                {space.description}
              </p>

              <p class="text-muted text-sm">
                {space.detail}
              </p>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="pull-quote text-center mb-10" style="border-left: none; padding-left: 0;">
        "We don't have room numbers. We have rooms with names, murals, and stories."
      </p>
      <a
        href={whatsappBook}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-8 py-4 text-lg bg-charcoal text-linen transition-colors hover:opacity-90"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Enquire About Staying
      </a>
    </div>
  </section>

</BaseLayout>
