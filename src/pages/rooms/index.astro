---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllRooms, siteInfo } from '../../utils/data';

const rooms = getAllRooms();
const whatsappEnquire = (roomName: string) =>
  `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent(`Hello! I'd like to enquire about ${roomName} at The Thyolo House.`)}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": siteInfo.name,
    "description": "Five unique rooms on the Conforzi Tea Estate — three suites in the main colonial house and two private cottages by the pool.",
    "url": `${siteInfo.url}/rooms/`,
    "telephone": siteInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Conforzi Tea Estate",
      "addressLocality": "Thyolo",
      "addressCountry": "MW"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Rooms", "item": `${siteInfo.url}/rooms/` }
    ]
  }
];
---

<BaseLayout
  title="Our Rooms & Cottages"
  description="Five unique rooms at The Thyolo House — three suites in the original colonial house and two private cottages by the pool on the Conforzi Tea Estate."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-16 md:py-24 bg-card border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-text mb-6" style="font-family: var(--font-heading);">Our Rooms & Cottages</h1>
      <p class="text-muted text-lg max-w-3xl mx-auto leading-relaxed">
        Three suites in the original early-1900s colonial house and two private cottages nestled by the swimming pool. Each room has its own character, blending heritage charm with modern comfort.
      </p>
    </div>
  </section>

  <!-- Rooms Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        {rooms.map((room, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 items-center ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <a href={`/rooms/${room.slug}/`}>
                <div class="aspect-video bg-primary/10 rounded-xl flex items-center justify-center text-muted hover:bg-primary/15 transition-colors">
                  <svg class="w-16 h-16 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
                </div>
              </a>
            </div>
            <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block text-xs font-medium uppercase tracking-wider text-accent bg-accent/10 px-2.5 py-1 rounded">
                  {room.type}
                </span>
                <span class="text-xs text-muted">
                  {room.location === 'main_house' ? 'Main House' : 'Poolside'}
                </span>
              </div>
              <h2 class="text-2xl md:text-3xl font-bold text-text mb-4" style="font-family: var(--font-heading);">
                <a href={`/rooms/${room.slug}/`} class="hover:text-primary transition-colors">{room.name}</a>
              </h2>
              <p class="text-muted leading-relaxed mb-6">{room.description}</p>

              <!-- Amenities -->
              <div class="flex flex-wrap gap-2 mb-6">
                {room.amenities.map((amenity) => (
                  <span class="inline-flex items-center text-xs text-text bg-bg border border-border px-3 py-1.5 rounded-full">
                    {amenity}
                  </span>
                ))}
              </div>

              <!-- Board Options -->
              <div class="mb-6">
                <p class="text-sm font-medium text-text mb-2">Board options:</p>
                <div class="flex flex-wrap gap-2">
                  {room.board_options.map((option) => (
                    <span class="text-xs text-primary bg-primary/10 px-2.5 py-1 rounded-full capitalize">{option.replace('-', ' ')}</span>
                  ))}
                </div>
              </div>

              <div class="flex items-center gap-4">
                <a
                  href={whatsappEnquire(room.name)}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-primary hover:bg-primary-hover rounded-lg transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Enquire on WhatsApp
                </a>
                <a href={`/rooms/${room.slug}/`} class="text-primary hover:text-primary-hover font-medium text-sm transition-colors">
                  View Details →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
