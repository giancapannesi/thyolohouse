---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllRooms, getRoomBySlug, siteInfo } from '../../utils/data';
import type { Room } from '../../utils/data';

export function getStaticPaths() {
  const rooms = getAllRooms();
  return rooms.map((room) => ({
    params: { slug: room.slug },
    props: { room },
  }));
}

interface Props {
  room: Room;
}

const { room } = Astro.props;
const allRooms = getAllRooms();
const otherRooms = allRooms.filter((r) => r.slug !== room.slug);

const roomHeroImages: Record<string, string> = {
  'heritage-suite': '/images/rooms/heritage-suite.jpg',
  'garden-suite': '/images/rooms/tree-mural.jpg',
  'tea-estate-suite': '/images/rooms/heritage-suite.jpg',
  'forest-cottage': '/images/estate/main-house.jpg',
  'pool-cottage': '/images/rooms/pool-cottage-room.jpg',
};

const roomThumbImages: Record<string, string> = {
  'heritage-suite': '/images/rooms/heritage-suite.jpg',
  'garden-suite': '/images/rooms/tree-mural.jpg',
  'tea-estate-suite': '/images/rooms/heritage-suite.jpg',
  'forest-cottage': '/images/estate/main-house.jpg',
  'pool-cottage': '/images/rooms/pool-cottage-room.jpg',
};

const whatsappBook = `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent(`Hello! I'd like to enquire about ${room.name} at The Thyolo House. Could you let me know availability?`)}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "HotelRoom",
    "name": room.name,
    "description": room.description,
    "url": `${siteInfo.url}/rooms/${room.slug}/`,
    "occupancy": {
      "@type": "QuantitativeValue",
      "value": room.capacity
    },
    "amenityFeature": room.amenities.map((a) => ({
      "@type": "LocationFeatureSpecification",
      "name": a,
      "value": true
    })),
    "containedInPlace": {
      "@type": "LodgingBusiness",
      "name": siteInfo.name,
      "url": siteInfo.url
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Rooms", "item": `${siteInfo.url}/rooms/` },
      { "@type": "ListItem", "position": 3, "name": room.name, "item": `${siteInfo.url}/rooms/${room.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={room.name}
  description={room.description}
  jsonLd={jsonLd}
>

  <!-- Hero Image -->
  <section class="relative overflow-hidden">
    <img src={roomHeroImages[room.slug] || '/images/rooms/heritage-suite.jpg'} alt={`${room.name} at The Thyolo House`} class="w-full aspect-[21/9] object-cover" />
  </section>

  <!-- Room Details -->
  <section class="py-20 md:py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-muted mb-12 label-caps" style="font-size: 0.6875rem;">
        <a href="/" class="hover:text-text transition-colors">Home</a>
        <span class="text-border">/</span>
        <a href="/rooms/" class="hover:text-text transition-colors">Rooms</a>
        <span class="text-border">/</span>
        <span class="text-text">{room.name}</span>
      </nav>

      <!-- Room Type & Location -->
      <p class="label-caps mb-6">
        {room.type === 'suite' ? 'Suite' : 'Cottage'}
        <span class="mx-2 text-border">/</span>
        {room.location === 'main_house' ? 'Main House' : 'Poolside'}
        <span class="mx-2 text-border">/</span>
        Sleeps {room.capacity}
      </p>

      <!-- Room Name -->
      <h1 class="text-4xl md:text-6xl text-text mb-10" style="font-family: var(--font-heading); font-weight: 300;">
        {room.name}
      </h1>

      <!-- Description -->
      <p class="text-lg text-muted leading-relaxed mb-16">
        {room.description}
      </p>

      <hr class="editorial" />

      <!-- Amenities -->
      <div class="py-12">
        <h2 class="text-2xl md:text-3xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">Amenities</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-y-4 gap-x-8">
          {room.amenities.map((amenity) => (
            <div class="flex items-center gap-3">
              <span class="w-1 h-1 bg-primary flex-shrink-0"></span>
              <span class="text-muted text-sm capitalize">{amenity}</span>
            </div>
          ))}
        </div>
      </div>

      <hr class="editorial" />

      <!-- Board Options -->
      <div class="py-12">
        <h2 class="text-2xl md:text-3xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">Board Options</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {room.board_options.map((option) => (
            <div class="border border-border p-8 text-center">
              <p class="label-caps mb-3 text-primary">{option.replace('-', ' ')}</p>
              <p class="text-muted text-sm">
                {option === 'self-catering' && 'Room only — shared kitchen facilities'}
                {option === 'half-board' && 'Breakfast and dinner included'}
                {option === 'full-board' && 'All meals included'}
              </p>
            </div>
          ))}
        </div>
      </div>

      <hr class="editorial" />

      <!-- WhatsApp Booking CTA -->
      <div class="py-12 text-center">
        <h2 class="text-2xl md:text-3xl text-text mb-4" style="font-family: var(--font-heading); font-weight: 300;">
          Enquire About This Room
        </h2>
        <p class="text-muted mb-8">
          Contact us on WhatsApp to check availability and make a reservation.
        </p>
        <a
          href={whatsappBook}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-8 py-4 text-lg bg-charcoal text-linen transition-colors hover:opacity-90"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Enquire on WhatsApp
        </a>
      </div>

    </div>
  </section>

  <!-- Other Rooms -->
  <section class="py-20 md:py-32 bg-card border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="label-caps mb-4">More Accommodation</p>
        <h2 class="text-3xl md:text-4xl text-text" style="font-family: var(--font-heading); font-weight: 300;">Other Rooms</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {otherRooms.map((r) => (
          <a href={`/rooms/${r.slug}/`} class="group">
            <div class="aspect-[4/3] mb-4 overflow-hidden">
              <img src={roomThumbImages[r.slug] || '/images/rooms/heritage-suite.jpg'} alt={`${r.name} at The Thyolo House`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <p class="label-caps mb-2">
              {r.type === 'suite' ? 'Suite' : 'Cottage'}
            </p>
            <h3 class="text-lg text-text group-hover:text-primary transition-colors" style="font-family: var(--font-heading); font-weight: 300;">
              {r.name}
            </h3>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
