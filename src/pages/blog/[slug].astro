---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllBlogPosts, getBlogPostBySlug, siteInfo } from '../../utils/data';
import type { BlogPost } from '../../utils/data';

export function getStaticPaths() {
  const posts = getAllBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.meta_title || post.title,
    "description": post.meta_description || post.excerpt,
    "datePublished": post.date,
    "author": {
      "@type": "Person",
      "name": post.author
    },
    "publisher": {
      "@type": "Organization",
      "name": siteInfo.name,
      "url": siteInfo.url
    },
    "url": `${siteInfo.url}/blog/${post.slug}/`,
    "image": post.image ? `${siteInfo.url}${post.image}` : `${siteInfo.url}/images/og-default.jpg`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Journal", "item": `${siteInfo.url}/blog/` },
      { "@type": "ListItem", "position": 3, "name": post.title, "item": `${siteInfo.url}/blog/${post.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={post.meta_title || post.title}
  description={post.meta_description || post.excerpt}
  jsonLd={jsonLd}
>

  <!-- Article -->
  <article class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-sm text-muted mb-8">
        <a href="/" class="hover:text-text transition-colors">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="/blog/" class="hover:text-text transition-colors">Journal</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-text truncate">{post.title}</span>
      </nav>

      <!-- Hero Image Placeholder -->
      <div class="aspect-video bg-primary/10 rounded-xl flex items-center justify-center text-muted mb-10">
        <svg class="w-16 h-16 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
      </div>

      <!-- Meta -->
      <div class="flex items-center gap-4 text-sm text-muted mb-6">
        <time datetime={post.date}>{formattedDate}</time>
        <span class="w-1 h-1 bg-muted rounded-full"></span>
        <span>By {post.author}</span>
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-5xl font-bold text-text mb-8 leading-tight" style="font-family: var(--font-heading);">
        {post.title}
      </h1>

      <!-- Tags -->
      {post.tags && post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {post.tags.map((tag) => (
            <span class="text-xs text-muted bg-bg border border-border px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}

      <!-- Content -->
      <div
        class="prose prose-lg max-w-none
          [&_h2]:font-bold [&_h2]:text-text [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
          [&_h3]:font-bold [&_h3]:text-text [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3
          [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4
          [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul_li]:text-muted [&_ul_li]:mb-1
          [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol_li]:text-muted [&_ol_li]:mb-1
          [&_a]:text-primary [&_a]:underline [&_a:hover]:text-primary-hover
          [&_blockquote]:border-l-4 [&_blockquote]:border-accent [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-muted [&_blockquote]:my-8
          [&_img]:rounded-xl [&_img]:my-8
          [&_strong]:text-text [&_strong]:font-semibold"
        set:html={post.content}
      />

      <!-- Back to Journal -->
      <div class="mt-16 pt-8 border-t border-border">
        <a href="/blog/" class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-medium transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          Back to Journal
        </a>
      </div>

    </div>
  </article>

</BaseLayout>
