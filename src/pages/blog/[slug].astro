---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllBlogPosts, getBlogPostBySlug, siteInfo } from '../../utils/data';
import type { BlogPost } from '../../utils/data';

export function getStaticPaths() {
  const posts = getAllBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.meta_title || post.title,
    "description": post.meta_description || post.excerpt,
    "datePublished": post.date,
    "author": {
      "@type": "Person",
      "name": post.author
    },
    "publisher": {
      "@type": "Organization",
      "name": siteInfo.name,
      "url": siteInfo.url
    },
    "url": `${siteInfo.url}/blog/${post.slug}/`,
    "image": post.image ? `${siteInfo.url}${post.image}` : `${siteInfo.url}/images/og-default.jpg`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Journal", "item": `${siteInfo.url}/blog/` },
      { "@type": "ListItem", "position": 3, "name": post.title, "item": `${siteInfo.url}/blog/${post.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={post.meta_title || post.title}
  description={post.meta_description || post.excerpt}
  jsonLd={jsonLd}
>

  <!-- Article -->
  <article>

    <!-- Hero Image -->
    <div class="img-placeholder aspect-[21/9]"></div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">

      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-muted mb-12 label-caps" style="font-size: 0.6875rem;">
        <a href="/" class="hover:text-text transition-colors">Home</a>
        <span class="text-border">/</span>
        <a href="/blog/" class="hover:text-text transition-colors">Journal</a>
        <span class="text-border">/</span>
        <span class="text-text truncate">{post.title}</span>
      </nav>

      <!-- Meta -->
      <div class="mb-8">
        <p class="label-caps">
          <time datetime={post.date}>{formattedDate}</time>
          <span class="mx-2 text-border">/</span>
          By {post.author}
        </p>
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-6xl text-text mb-10 leading-tight" style="font-family: var(--font-heading); font-weight: 300;">
        {post.title}
      </h1>

      <!-- Tags -->
      {post.tags && post.tags.length > 0 && (
        <div class="flex flex-wrap gap-3 mb-12">
          {post.tags.map((tag) => (
            <span class="label-caps px-3 py-1 border border-border">{tag}</span>
          ))}
        </div>
      )}

      <hr class="editorial" />

      <!-- Content -->
      <div
        class="prose prose-lg max-w-none
          [&_h2]:text-text [&_h2]:text-2xl [&_h2]:md:text-3xl [&_h2]:mt-12 [&_h2]:mb-6
          [&_h3]:text-text [&_h3]:text-xl [&_h3]:md:text-2xl [&_h3]:mt-10 [&_h3]:mb-4
          [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-6
          [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul_li]:text-muted [&_ul_li]:mb-2
          [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol_li]:text-muted [&_ol_li]:mb-2
          [&_a]:text-primary [&_a]:underline [&_a:hover]:text-primary-hover
          [&_blockquote]:pull-quote [&_blockquote]:my-10
          [&_img]:my-10
          [&_strong]:text-text"
        style="font-weight: 300;"
        set:html={post.content}
      />

      <hr class="editorial" />

      <!-- Back to Journal -->
      <div class="mt-12">
        <a href="/blog/" class="inline-flex items-center gap-2 text-text border-b border-text pb-0.5 hover:text-primary hover:border-primary transition-colors text-sm" style="font-weight: 400;">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          Back to Journal
        </a>
      </div>

    </div>
  </article>

</BaseLayout>
