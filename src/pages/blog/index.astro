---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllBlogPosts, siteInfo } from '../../utils/data';

const posts = getAllBlogPosts();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Journal — The Thyolo House",
    "description": "Stories, recipes, and reflections from The Thyolo House on the Conforzi Tea Estate in Thyolo, Malawi.",
    "url": `${siteInfo.url}/blog/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Journal", "item": `${siteInfo.url}/blog/` }
    ]
  }
];
---

<BaseLayout
  title="Journal"
  description="Stories, recipes, and reflections from The Thyolo House — a boutique retreat on the Conforzi Tea Estate in Thyolo, Malawi."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
      <p class="label-caps mb-6">Stories & Reflections</p>
      <h1 class="text-5xl md:text-7xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">
        Journal
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Stories, recipes, and reflections from life on the Conforzi Tea Estate.
      </p>
    </div>
  </section>

  <div class="ornament max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">&#10038;</div>

  <!-- Blog Posts -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      {posts.length > 0 ? (
        <div class="space-y-16">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}/`} class="group block">
              <div class={`grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center`}>

                <!-- Image -->
                <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
                  <div class="img-placeholder aspect-[4/3]"></div>
                </div>

                <!-- Text -->
                <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
                  <p class="label-caps mb-4">
                    {new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </p>
                  <h2 class="text-2xl md:text-3xl text-text group-hover:text-primary transition-colors mb-4" style="font-family: var(--font-heading); font-weight: 300;">
                    {post.title}
                  </h2>
                  <p class="text-muted leading-relaxed mb-6 line-clamp-3">{post.excerpt}</p>
                  <span class="text-text text-sm border-b border-text pb-0.5 group-hover:text-primary group-hover:border-primary transition-colors">
                    Read More
                  </span>
                </div>
              </div>

              {i < posts.length - 1 && (
                <hr class="editorial mt-16" />
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="label-caps mb-6 text-primary">Coming Soon</p>
          <h2 class="text-3xl md:text-4xl text-text mb-4" style="font-family: var(--font-heading); font-weight: 300;">No posts yet</h2>
          <p class="text-muted text-lg">Check back soon — we are working on stories from the estate.</p>
        </div>
      )}

    </div>
  </section>

</BaseLayout>
