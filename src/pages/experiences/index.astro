---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllExperiences, siteInfo } from '../../utils/data';

const experiences = getAllExperiences();

const whatsappBook = (name: string) =>
  `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent(`Hello! I'd like to book the ${name} experience at The Thyolo House.`)}`;

const experienceImages: Record<string, string> = {
  'pool-garden': '/images/estate/pool-area.jpg',
  'art-studio': '/images/gallery/art-african-modern.jpg',
  'tea-walks': '/images/estate/garden-view.jpg',
  'forest-trails': '/images/estate/garden-path.jpg',
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Experiences at The Thyolo House",
    "description": "Activities and experiences available at The Thyolo House on the Conforzi Tea Estate.",
    "url": `${siteInfo.url}/experiences/`,
    "itemListElement": experiences.map((exp, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": exp.name,
      "description": exp.description
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Experiences", "item": `${siteInfo.url}/experiences/` }
    ]
  }
];
---

<BaseLayout
  title="Experiences"
  description="Tea plantation walks, art workshops, forest trails, and pool-side relaxation at The Thyolo House on the Conforzi Tea Estate in Thyolo, Malawi."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
      <p class="label-caps mb-6">Things to Do</p>
      <h1 class="text-5xl md:text-7xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">
        Experiences
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        From tea plantation walks to creative workshops in Flavia's art studio, every day at The Thyolo House offers something to nourish the soul.
      </p>
    </div>
  </section>

  <div class="ornament max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">&#10038;</div>

  <!-- Experiences — Editorial Blocks -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-20 md:space-y-32">
        {experiences.map((exp, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start ${i % 2 === 1 ? '' : ''}`}>

            <!-- Experience Image -->
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="aspect-[3/4] overflow-hidden">
                <img src={experienceImages[exp.slug] || '/images/estate/garden-view.jpg'} alt={`${exp.name} at The Thyolo House on the Conforzi Tea Estate`} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>

            <!-- Text Content -->
            <div class={`${i % 2 === 1 ? 'lg:order-1' : ''} flex flex-col justify-center`}>
              <p class="label-caps mb-4">{exp.duration}</p>

              <h2 class="text-3xl md:text-4xl text-text mb-6" style="font-family: var(--font-heading); font-weight: 300;">
                {exp.name}
              </h2>

              <p class="text-muted leading-relaxed mb-8">{exp.description}</p>

              <!-- Includes -->
              {exp.includes.length > 0 && (
                <div class="mb-8">
                  <p class="label-caps mb-4">Includes</p>
                  <ul class="space-y-2">
                    {exp.includes.map((item) => (
                      <li class="flex items-start gap-3 text-muted text-sm">
                        <span class="w-1 h-1 bg-primary flex-shrink-0 mt-2"></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <!-- Booking Note & CTA -->
              <div class="flex items-center gap-6">
                {exp.booking_required ? (
                  <a
                    href={whatsappBook(exp.name)}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-2 px-6 py-3 text-sm bg-charcoal text-linen transition-colors hover:opacity-90"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Book This Experience
                  </a>
                ) : (
                  <p class="text-muted text-sm italic">Available to all guests</p>
                )}
                {exp.booking_required && (
                  <p class="label-caps text-primary">Booking Required</p>
                )}
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="ornament max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">&#10038;</div>

  <!-- General CTA -->
  <section class="py-20 md:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl text-text mb-6" style="font-family: var(--font-heading); font-weight: 300;">Want to Know More?</h2>
      <p class="text-muted text-lg mb-10 leading-relaxed">
        Get in touch to plan your stay and we will help you make the most of your time at The Thyolo House.
      </p>
      <a
        href={`https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent("Hello! I'd like to know more about experiences at The Thyolo House.")}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-8 py-4 text-lg bg-charcoal text-linen transition-colors hover:opacity-90"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Get in Touch
      </a>
    </div>
  </section>

</BaseLayout>
