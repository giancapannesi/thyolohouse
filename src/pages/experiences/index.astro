---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllExperiences, siteInfo } from '../../utils/data';

const experiences = getAllExperiences();

const whatsappBook = (name: string) =>
  `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent(`Hello! I'd like to book the ${name} experience at The Thyolo House.`)}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Experiences at The Thyolo House",
    "description": "Activities and experiences available at The Thyolo House on the Conforzi Tea Estate.",
    "url": `${siteInfo.url}/experiences/`,
    "itemListElement": experiences.map((exp, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": exp.name,
      "description": exp.description
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Experiences", "item": `${siteInfo.url}/experiences/` }
    ]
  }
];

const iconMap: Record<string, string> = {
  palette: 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  leaf: 'M12 21c-4-4-8-7.5-8-12a8 8 0 0116 0c0 4.5-4 8-8 12zM12 13V7',
  trees: 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  sun: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z',
};
---

<BaseLayout
  title="Experiences"
  description="Tea plantation walks, art workshops, forest trails, and pool-side relaxation at The Thyolo House on the Conforzi Tea Estate in Thyolo, Malawi."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-16 md:py-24 bg-card border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-text mb-6" style="font-family: var(--font-heading);">Experiences</h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        From tea plantation walks to creative workshops in Flavia's art studio, every day at The Thyolo House offers something to nourish the soul.
      </p>
    </div>
  </section>

  <!-- Experiences Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {experiences.map((exp) => (
          <div class="bg-card rounded-xl border border-border overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-video bg-primary/10 flex items-center justify-center text-muted">
              <svg class="w-16 h-16 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={iconMap[exp.icon] || iconMap.sun} /></svg>
            </div>
            <div class="p-8">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center text-primary flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={iconMap[exp.icon] || iconMap.sun} /></svg>
                </div>
                <h2 class="text-xl font-bold text-text" style="font-family: var(--font-heading);">{exp.name}</h2>
              </div>

              <p class="text-muted leading-relaxed mb-6">{exp.description}</p>

              <!-- Duration -->
              <div class="flex items-center gap-2 text-sm text-muted mb-4">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span>{exp.duration}</span>
              </div>

              <!-- Includes -->
              <div class="mb-6">
                <p class="text-sm font-medium text-text mb-2">Includes:</p>
                <ul class="space-y-1.5">
                  {exp.includes.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-muted">
                      <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Booking Badge & CTA -->
              <div class="flex items-center justify-between">
                {exp.booking_required ? (
                  <span class="inline-flex items-center gap-1.5 text-xs font-medium text-accent bg-accent/10 px-3 py-1.5 rounded-full">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Booking required
                  </span>
                ) : (
                  <span class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-primary/10 px-3 py-1.5 rounded-full">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    Available to all guests
                  </span>
                )}
                {exp.booking_required && (
                  <a
                    href={whatsappBook(exp.name)}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-primary hover:bg-primary-hover rounded-lg transition-colors"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Book
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- General Booking CTA -->
  <section class="py-16 bg-card border-t border-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-text mb-4" style="font-family: var(--font-heading);">Want to Know More?</h2>
      <p class="text-muted text-lg mb-8">
        Get in touch to plan your stay and we will help you make the most of your time at The Thyolo House.
      </p>
      <a
        href={`https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent("Hello! I'd like to know more about experiences at The Thyolo House.")}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-8 py-4 text-lg font-semibold text-white bg-primary hover:bg-primary-hover rounded-lg transition-colors shadow-lg"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Contact Us on WhatsApp
      </a>
    </div>
  </section>

</BaseLayout>
