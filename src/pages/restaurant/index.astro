---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMenu, siteInfo } from '../../utils/data';

const menu = getMenu();
const whatsappReserve = `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent("Hello! I'd like to make a restaurant reservation at The Thyolo House.")}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": "The Thyolo House Restaurant",
    "description": "Italian fusion restaurant with garden-to-table ingredients on the historic Conforzi Tea Estate in Thyolo, Malawi.",
    "url": `${siteInfo.url}/restaurant/`,
    "servesCuisine": ["Italian", "Fusion", "Garden-to-Table"],
    "telephone": siteInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Conforzi Tea Estate",
      "addressLocality": "Thyolo",
      "addressCountry": "MW"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": siteInfo.geo.lat,
      "longitude": siteInfo.geo.lng
    },
    "hasMenu": {
      "@type": "Menu",
      "name": "The Thyolo House Menu",
      "hasMenuSection": menu.categories.map((cat) => ({
        "@type": "MenuSection",
        "name": cat.name,
        "description": cat.description,
        "hasMenuItem": cat.items.map((item) => ({
          "@type": "MenuItem",
          "name": item.name,
          "description": item.description,
          "suitableForDiet": item.dietary.map((d) =>
            d === 'vegetarian' ? 'https://schema.org/VegetarianDiet'
            : d === 'vegan' ? 'https://schema.org/VeganDiet'
            : d === 'gluten-free' ? 'https://schema.org/GlutenFreeDiet'
            : undefined
          ).filter(Boolean)
        }))
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Restaurant", "item": `${siteInfo.url}/restaurant/` }
    ]
  }
];
---

<BaseLayout
  title="Our Restaurant"
  description="Italian fusion cuisine with garden-to-table ingredients at The Thyolo House on the Conforzi Tea Estate. Fresh pasta, Lake Malawi fish, and estate-grown teas and coffees."
  jsonLd={jsonLd}
>

  <!-- Page Header -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
      <p class="label-caps mb-6">Dining</p>
      <h1 class="text-5xl md:text-7xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">
        Our Restaurant
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Where Italian tradition meets Malawian soul, served in the warmth of a colonial farmhouse.
      </p>
    </div>
  </section>

  <!-- Story & Image -->
  <section class="pb-20 md:pb-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <h2 class="text-3xl md:text-4xl text-text mb-8" style="font-family: var(--font-heading); font-weight: 300;">Garden to Table</h2>
          <p class="text-muted leading-relaxed mb-6">{menu.intro}</p>
          <p class="text-muted leading-relaxed mb-6">
            Our chemical-free garden supplies fresh herbs, vegetables, and edible flowers daily. What we cannot grow, we source locally — Lake Malawi chambo, free-range chicken, and tropical fruits from the surrounding region.
          </p>
          <p class="text-muted leading-relaxed">
            Whether you join us for a leisurely lunch on the veranda or a candlelit dinner under the stars, every meal at The Thyolo House is crafted with care and seasoned with the story of this place.
          </p>
        </div>
        <div>
          <div class="aspect-[3/4] overflow-hidden">
            <img src="/images/food/cotoletta-salad.jpg" alt="Cotoletta milanese with fresh garden salad served on gold-rimmed plate at The Thyolo House" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull Quote -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="pull-quote">
        "The kitchen is not separate from the garden. The garden is not separate from the land. Everything here is connected — that is what you taste."
      </p>
    </div>
  </section>

  <!-- Restaurant Gallery -->
  <section class="pb-16 md:pb-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/estate/restaurant-night.jpg" alt="The Thyolo House restaurant entrance at night with candles and warm light" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/food/outdoor-dining.jpg" alt="Outdoor dining at The Thyolo House — cotoletta with fresh salad and garden view" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/food/pork-chops.jpg" alt="Grilled pork chops with roast potatoes and rosemary at The Thyolo House" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
      </div>

      <!-- Second row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/rooms/dining-room.jpg" alt="Atmospheric dining room with dark wood table and hanging plants" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/food/cotoletta-overhead.jpg" alt="Cotoletta milanese and garden salad viewed from above" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/estate/restaurant-exterior.jpg" alt="The Thyolo House restaurant building with white curtains and garden flowers" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <div class="ornament max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">&#10038;</div>

  <!-- Menu -->
  <section class="py-20 md:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="label-caps mb-4">A Seasonal Selection</p>
        <h2 class="text-4xl md:text-5xl text-text mb-4" style="font-family: var(--font-heading); font-weight: 300;">Our Menu</h2>
        <p class="text-muted text-sm">Our menu changes with the seasons and what the garden provides.</p>
      </div>

      <div class="space-y-20">
        {menu.categories.map((category) => (
          <div>
            <!-- Category Header -->
            <div class="text-center mb-10">
              <h3 class="text-2xl md:text-3xl text-text mb-2" style="font-family: var(--font-heading); font-weight: 300;">{category.name}</h3>
              <p class="text-muted text-sm italic">{category.description}</p>
              <div class="ornament mt-6 mb-0">&#183;</div>
            </div>

            <!-- Menu Items -->
            <div class="space-y-8">
              {category.items.map((item) => (
                <div class="group">
                  <div class="flex items-baseline gap-2 mb-1">
                    <h4 class="text-text text-lg" style="font-family: var(--font-heading);">{item.name}</h4>
                    {item.dietary.length > 0 && (
                      <span class="text-accent text-xs">
                        {item.dietary.map((d: string) =>
                          d === 'gluten-free' ? 'GF' : d === 'vegetarian' ? 'V' : d === 'vegan' ? 'VG' : d
                        ).join(' ')}
                      </span>
                    )}
                    <span class="flex-1 border-b border-dotted border-border mx-2 mb-1"></span>
                    {item.price && (
                      <span class="text-muted text-sm whitespace-nowrap">MK {item.price.toLocaleString()}</span>
                    )}
                  </div>
                  <p class="text-muted text-sm leading-relaxed pl-0">{item.description}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Dietary Key -->
      <div class="mt-16 pt-8 border-t border-border">
        <p class="label-caps mb-4">Dietary Key</p>
        <div class="flex flex-wrap gap-6">
          <span class="text-muted text-sm"><span class="text-accent">V</span> Vegetarian</span>
          <span class="text-muted text-sm"><span class="text-accent">VG</span> Vegan</span>
          <span class="text-muted text-sm"><span class="text-accent">GF</span> Gluten Free</span>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">&#10038;</div>

  <!-- Reservation CTA -->
  <section class="py-20 md:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="label-caps mb-4">Reservations</p>
      <h2 class="text-3xl md:text-5xl text-text mb-6" style="font-family: var(--font-heading); font-weight: 300;">Reserve a Table</h2>
      <p class="text-muted text-lg mb-10 leading-relaxed">
        We welcome both hotel guests and visitors for lunch and dinner. Please book ahead so we can prepare something special for you.
      </p>
      <a
        href={whatsappReserve}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-8 py-4 text-lg bg-charcoal text-linen transition-colors hover:opacity-90"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Reserve on WhatsApp
      </a>
    </div>
  </section>

</BaseLayout>
