---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMenu, siteInfo } from '../../utils/data';

const menu = getMenu();
const whatsappReserve = `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent("Hello! I'd like to make a restaurant reservation at The Thyolo House.")}`;

const dietaryColors: Record<string, string> = {
  'vegetarian': 'bg-green-100 text-green-800',
  'vegan': 'bg-emerald-100 text-emerald-800',
  'gluten-free': 'bg-amber-100 text-amber-800',
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": "The Thyolo House Restaurant",
    "description": "Italian fusion restaurant with garden-to-table ingredients on the historic Conforzi Tea Estate in Thyolo, Malawi.",
    "url": `${siteInfo.url}/restaurant/`,
    "servesCuisine": ["Italian", "Fusion", "Garden-to-Table"],
    "telephone": siteInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Conforzi Tea Estate",
      "addressLocality": "Thyolo",
      "addressCountry": "MW"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": siteInfo.geo.lat,
      "longitude": siteInfo.geo.lng
    },
    "hasMenu": {
      "@type": "Menu",
      "name": "The Thyolo House Menu",
      "hasMenuSection": menu.categories.map((cat) => ({
        "@type": "MenuSection",
        "name": cat.name,
        "description": cat.description,
        "hasMenuItem": cat.items.map((item) => ({
          "@type": "MenuItem",
          "name": item.name,
          "description": item.description,
          "suitableForDiet": item.dietary.map((d) =>
            d === 'vegetarian' ? 'https://schema.org/VegetarianDiet'
            : d === 'vegan' ? 'https://schema.org/VeganDiet'
            : d === 'gluten-free' ? 'https://schema.org/GlutenFreeDiet'
            : undefined
          ).filter(Boolean)
        }))
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteInfo.url },
      { "@type": "ListItem", "position": 2, "name": "Restaurant", "item": `${siteInfo.url}/restaurant/` }
    ]
  }
];
---

<BaseLayout
  title="Our Restaurant"
  description="Italian fusion cuisine with garden-to-table ingredients at The Thyolo House on the Conforzi Tea Estate. Fresh pasta, Lake Malawi fish, and estate-grown teas and coffees."
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="relative py-20 md:py-32 bg-gradient-to-br from-primary/20 via-primary/10 to-accent/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-text mb-6" style="font-family: var(--font-heading);">Our Restaurant</h1>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Where Italian tradition meets Malawian soul, served in the warmth of a colonial farmhouse.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-3">
          <h2 class="text-2xl md:text-3xl font-bold text-text mb-6" style="font-family: var(--font-heading);">Garden to Table</h2>
          <p class="text-muted leading-relaxed mb-4">{menu.intro}</p>
          <p class="text-muted leading-relaxed mb-4">
            Our chemical-free garden supplies fresh herbs, vegetables, and edible flowers daily. What we cannot grow, we source locally — Lake Malawi chambo, free-range chicken, and tropical fruits from the surrounding region.
          </p>
          <p class="text-muted leading-relaxed">
            Whether you join us for a leisurely lunch on the veranda or a candlelit dinner under the stars, every meal at The Thyolo House is crafted with care and seasoned with the story of this place.
          </p>
        </div>
        <div class="lg:col-span-2">
          <div class="aspect-[3/4] bg-primary/10 rounded-xl flex items-center justify-center text-muted">
            <svg class="w-14 h-14 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu -->
  <section class="py-16 md:py-24 bg-card border-y border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-4" style="font-family: var(--font-heading);">Our Menu</h2>
        <p class="text-muted">Our menu changes with the seasons and what the garden provides. Below is a representative selection.</p>
      </div>

      <div class="space-y-16">
        {menu.categories.map((category) => (
          <div>
            <div class="text-center mb-8">
              <h3 class="text-2xl font-bold text-text mb-2" style="font-family: var(--font-heading);">{category.name}</h3>
              <p class="text-muted text-sm italic">{category.description}</p>
              <div class="w-12 h-px bg-accent mx-auto mt-4"></div>
            </div>
            <div class="space-y-6">
              {category.items.map((item) => (
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 pb-6 border-b border-border last:border-0 last:pb-0">
                  <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                      <h4 class="font-semibold text-text text-lg">{item.name}</h4>
                      <div class="flex gap-1.5">
                        {item.dietary.map((d) => (
                          <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${dietaryColors[d] || 'bg-gray-100 text-gray-700'}`}>
                            {d === 'gluten-free' ? 'GF' : d === 'vegetarian' ? 'V' : d === 'vegan' ? 'VG' : d}
                          </span>
                        ))}
                      </div>
                    </div>
                    <p class="text-muted text-sm leading-relaxed">{item.description}</p>
                  </div>
                  {item.price && (
                    <span class="text-primary font-semibold whitespace-nowrap">MK {item.price.toLocaleString()}</span>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Dietary Key -->
      <div class="mt-16 pt-8 border-t border-border">
        <p class="text-sm text-muted mb-3">Dietary key:</p>
        <div class="flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 text-xs"><span class="bg-green-100 text-green-800 px-2 py-0.5 rounded-full font-medium">V</span> Vegetarian</span>
          <span class="inline-flex items-center gap-1.5 text-xs"><span class="bg-emerald-100 text-emerald-800 px-2 py-0.5 rounded-full font-medium">VG</span> Vegan</span>
          <span class="inline-flex items-center gap-1.5 text-xs"><span class="bg-amber-100 text-amber-800 px-2 py-0.5 rounded-full font-medium">GF</span> Gluten Free</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Reservation CTA -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-text mb-4" style="font-family: var(--font-heading);">Reserve a Table</h2>
      <p class="text-muted text-lg mb-8 leading-relaxed">
        We welcome both hotel guests and visitors for lunch and dinner. Please book ahead so we can prepare something special for you.
      </p>
      <a
        href={whatsappReserve}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-8 py-4 text-lg font-semibold text-white bg-primary hover:bg-primary-hover rounded-lg transition-colors shadow-lg"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Reserve on WhatsApp
      </a>
    </div>
  </section>

</BaseLayout>
