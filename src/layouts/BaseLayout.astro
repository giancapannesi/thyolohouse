---
import '../styles/global.css';
import { siteInfo } from '../utils/data';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object | object[];
}

const { title, description, canonical, ogImage, jsonLd } = Astro.props;
const fullTitle = title.includes('Thyolo House') ? title : `${title} | The Thyolo House`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteInfo.url).toString();
const ogImg = ogImage || `${siteInfo.url}/images/og-default.jpg`;
const whatsappUrl = `https://wa.me/${siteInfo.whatsapp}?text=${encodeURIComponent('Hello! I\'d like to enquire about availability at The Thyolo House.')}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:site_name" content="The Thyolo House" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />
  {jsonLd && (
    Array.isArray(jsonLd) ? (
      jsonLd.map(ld => (
        <script type="application/ld+json" set:html={JSON.stringify(ld)} />
      ))
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )
  )}
</head>
<body class="min-h-screen flex flex-col">
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-bg/95 backdrop-blur border-b border-border" id="main-nav">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-20">
        <a href="/" class="flex items-center gap-2 font-heading text-xl md:text-2xl font-bold text-text hover:text-primary transition-colors" style="font-family: var(--font-heading);">
          The Thyolo House
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6">
          <a href="/rooms/" class="text-muted hover:text-text text-sm font-medium transition-colors">Rooms</a>
          <a href="/restaurant/" class="text-muted hover:text-text text-sm font-medium transition-colors">Restaurant</a>
          <a href="/experiences/" class="text-muted hover:text-text text-sm font-medium transition-colors">Experiences</a>
          <a href="/gallery/" class="text-muted hover:text-text text-sm font-medium transition-colors">Gallery</a>
          <a href="/about/" class="text-muted hover:text-text text-sm font-medium transition-colors">About</a>
          <a href="/contact/" class="text-muted hover:text-text text-sm font-medium transition-colors">Contact</a>
        </div>
        <div class="hidden md:flex items-center gap-3">
          <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-primary hover:bg-primary-hover rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Book Now
          </a>
        </div>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-muted hover:text-text" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-bg">
      <div class="px-4 py-4 space-y-3">
        <a href="/rooms/" class="block text-text hover:text-primary font-medium transition-colors">Rooms</a>
        <a href="/restaurant/" class="block text-text hover:text-primary font-medium transition-colors">Restaurant</a>
        <a href="/experiences/" class="block text-text hover:text-primary font-medium transition-colors">Experiences</a>
        <a href="/gallery/" class="block text-text hover:text-primary font-medium transition-colors">Gallery</a>
        <a href="/about/" class="block text-text hover:text-primary font-medium transition-colors">About</a>
        <a href="/contact/" class="block text-text hover:text-primary font-medium transition-colors">Contact</a>
        <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-primary rounded-lg mt-2">
          Book via WhatsApp
        </a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-text text-bg/90 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">The Thyolo House</h3>
          <p class="text-sm opacity-80 mb-4">{siteInfo.description.slice(0, 150)}...</p>
          <div class="flex gap-4">
            <a href={siteInfo.facebook} target="_blank" rel="noopener" class="opacity-70 hover:opacity-100 transition-opacity" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href={siteInfo.instagram} target="_blank" rel="noopener" class="opacity-70 hover:opacity-100 transition-opacity" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Quick Links</h3>
          <ul class="space-y-2 text-sm opacity-80">
            <li><a href="/rooms/" class="hover:opacity-100 transition-opacity">Our Rooms</a></li>
            <li><a href="/restaurant/" class="hover:opacity-100 transition-opacity">Restaurant & Menu</a></li>
            <li><a href="/experiences/" class="hover:opacity-100 transition-opacity">Experiences</a></li>
            <li><a href="/gallery/" class="hover:opacity-100 transition-opacity">Photo Gallery</a></li>
            <li><a href="/about/" class="hover:opacity-100 transition-opacity">Our Story</a></li>
            <li><a href="/blog/" class="hover:opacity-100 transition-opacity">Journal</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Get In Touch</h3>
          <ul class="space-y-3 text-sm opacity-80">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              Conforzi Tea Estate, Thyolo, Malawi
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <a href={`mailto:${siteInfo.email}`} class="hover:opacity-100 transition-opacity">{siteInfo.email}</a>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <a href={whatsappUrl} target="_blank" rel="noopener" class="hover:opacity-100 transition-opacity">+265 884 202 040</a>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-10 pt-6 border-t border-bg/20 text-center">
        <p class="text-sm opacity-60">&copy; {new Date().getFullYear()} The Thyolo House. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
